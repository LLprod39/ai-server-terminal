# =============================================================================
# WEU AI Agent Platform — mini_prod configuration
# Скопируйте в .env и заполните нужные поля.
# =============================================================================

# -----------------------------------------------------------------------------
# База данных (PostgreSQL через Docker)
# Если не задано — используется SQLite (только для разработки)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=weu_platform
POSTGRES_USER=weu
POSTGRES_PASSWORD=weu_secret_change_me

# -----------------------------------------------------------------------------
# LLM провайдеры — задайте нужный ключ
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# GROK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Сервер и безопасность
# -----------------------------------------------------------------------------
# Публичный URL сервера — используется в ссылках для подтверждения обновлений
SITE_URL=http://localhost:8000

# URL внешнего React SPA. Для локальной разработки это Vite (:8080),
# для Render static site — адрес frontend-сервиса.
FRONTEND_APP_URL=http://127.0.0.1:8080

# Production toggles. На Render обычно нужны:
# DJANGO_DEBUG=false
# CROSS_SITE_AUTH=true
# DJANGO_SECRET_KEY=<random-secret>
DJANGO_DEBUG=true
# DJANGO_SECRET_KEY=
# CROSS_SITE_AUTH=false

# Если frontend и backend живут на разных origin, можно явно переопределить.
# По умолчанию backend возьмёт FRONTEND_APP_URL как разрешённый frontend origin.
# CORS_ALLOWED_ORIGINS=https://frontend.example.com
# CSRF_TRUSTED_ORIGINS=https://frontend.example.com

# Разрешённые хосты (через запятую)
# ALLOWED_HOSTS=myserver.example.com,localhost

# CSRF origins (через запятую)
# CSRF_TRUSTED_ORIGINS=https://myserver.example.com

# Секретный ключ Django (смените в продакшене!)
# SECRET_KEY=

# -----------------------------------------------------------------------------
# Email (SMTP) — уведомления, отчёты, письма с подтверждением обновлений
# -----------------------------------------------------------------------------
# Вариант 1: Gmail (App Password)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
#
# Вариант 2: Яндекс.Почта — пароль приложения: https://yandex.ru/support/yandex-360/customers/mail/ru/mail-clients/others
# EMAIL_HOST=smtp.yandex.ru
# EMAIL_PORT=465

EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_TLS=True

# Логин (для Яндекса — часть до @, например yourlogin) и пароль приложения
EMAIL_HOST_USER=yourlogin
EMAIL_HOST_PASSWORD=your-app-password

# Адрес отправителя (полный email)
DEFAULT_FROM_EMAIL=WEU Platform <yourlogin@yandex.ru>

# Кому отправлять уведомления пайплайнов
PIPELINE_NOTIFY_EMAIL=yourlogin@yandex.ru

# -----------------------------------------------------------------------------
# Telegram Bot — уведомления и подтверждения прямо в мессенджер
#
# Как настроить за 2 минуты:
#   1. Напишите @BotFather в Telegram → /newbot → получите токен
#   2. Запустите бота (напишите ему /start)
#   3. Узнайте свой chat_id: напишите @userinfobot или @getidsbot
#   4. Заполните переменные ниже
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# -----------------------------------------------------------------------------
# Прочее
# -----------------------------------------------------------------------------
# MASTER_PASSWORD=        # Ключ шифрования паролей серверов
# CHANNEL_REDIS_URL=      # Redis для WebSocket-каналов (по умолчанию — in-memory)
