<Page
    x:Class="MiniProd.Desktop.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel MaxWidth="540" Spacing="18">
                <Border Style="{StaticResource HeroCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="Connect to the central backend" />
                        <TextBlock
                            Foreground="{StaticResource ShellSubtleTextBrush}"
                            Text="This page is wired to the planned desktop auth endpoint and stores session state in the local shell service."
                            TextWrapping="WrapWholeWords" />

                        <TextBox
                            x:Name="UsernameInput"
                            Header="Username"
                            PlaceholderText="admin" />

                        <PasswordBox
                            x:Name="PasswordInput"
                            Header="Password"
                            PasswordChanged="OnPasswordChanged" />

                        <Button
                            HorizontalAlignment="Left"
                            Click="OnSignInClicked"
                            Content="Sign in" />

                        <TextBlock
                            x:Name="StatusMessageText"
                            Foreground="{StaticResource ShellSubtleTextBrush}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource HeroCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Planned desktop auth flow" />
                        <TextBlock Text="1. POST /api/desktop/v1/auth/login" />
                        <TextBlock Text="2. Access token held in the desktop session service" />
                        <TextBlock Text="3. Refresh rotation handled by the backend contract" />
                        <TextBlock Text="4. Terminal page requests short-lived WS tickets before opening sessions" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
