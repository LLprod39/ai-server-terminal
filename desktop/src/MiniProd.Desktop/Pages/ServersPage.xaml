<Page
    x:Class="MiniProd.Desktop.Pages.ServersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="ServerListItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </Page.Resources>

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="SERVER VAULT" />
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Saved servers" />
                <TextBlock
                    Style="{StaticResource BodyMutedTextStyle}"
                    Text="Quickly manage local SSH entries and jump to terminal in one click." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Style="{StaticResource PillBorderStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Total" />
                            <TextBlock x:Name="TotalServersText" Style="{StaticResource CaptionTextStyle}" Text="0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SuccessBadgeStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource ShellSuccessTextBrush}" Text="Ready" />
                            <TextBlock x:Name="ReadyServersText" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource ShellSuccessTextBrush}" Text="0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WarningBadgeStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource ShellWarningTextBrush}" Text="Error" />
                            <TextBlock x:Name="ErrorServersText" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource ShellWarningTextBrush}" Text="0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                <Button Click="OnNewClicked" Content="New" Style="{StaticResource SecondaryButtonStyle}" />
                <Button Click="OnSaveClicked" Content="Save" Style="{StaticResource PrimaryButtonStyle}" />
                <Button Click="OnOpenTerminalClicked" Content="Open terminal" Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource WorkspacePanelStyle}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Library" />

                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="SearchInput"
                            PlaceholderText="Search by name, host, or user"
                            TextChanged="OnSearchChanged" />
                        <ComboBox
                            x:Name="StatusFilterSelector"
                            Grid.Column="1"
                            SelectionChanged="OnStatusFilterChanged">
                            <x:String>all</x:String>
                            <x:String>ready</x:String>
                            <x:String>error</x:String>
                            <x:String>new</x:String>
                        </ComboBox>
                    </Grid>

                    <ListView
                        x:Name="ServersList"
                        Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource ServerListItemStyle}"
                        SelectionChanged="OnServerSelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Background="{StaticResource ShellSecondaryBrush}"
                                    BorderBrush="{StaticResource ShellBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12,10">
                                    <StackPanel Spacing="3">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock Style="{StaticResource MonoTextStyle}" Text="{Binding AddressLabel}" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding StatusLabel}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Grid.Row="3" Style="{StaticResource WorkspaceSubtleStyle}">
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="Secrets are encrypted locally under your Windows account."
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource WorkspacePanelStyle}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="FormModeText" Style="{StaticResource SectionTitleTextStyle}" Text="New server" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="Configure connection details and authentication." />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">
                            <Border Style="{StaticResource InsetPanelStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="IDENTITY" />
                                    <TextBox
                                        x:Name="NameInput"
                                        Header="Display name"
                                        PlaceholderText="prod-web-01" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InsetPanelStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="CONNECTION" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox
                                            x:Name="HostInput"
                                            Header="Host"
                                            PlaceholderText="192.168.1.10" />
                                        <NumberBox
                                            x:Name="PortInput"
                                            Grid.Column="1"
                                            Header="Port"
                                            Maximum="65535"
                                            Minimum="1"
                                            SmallChange="1"
                                            SpinButtonPlacementMode="Compact" />
                                    </Grid>
                                    <TextBox
                                        x:Name="UsernameInput"
                                        Header="Username"
                                        PlaceholderText="root" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InsetPanelStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="AUTHENTICATION" />
                                    <ComboBox
                                        x:Name="AuthMethodSelector"
                                        Header="Method"
                                        HorizontalAlignment="Stretch"
                                        SelectionChanged="OnAuthMethodChanged">
                                        <x:String>password</x:String>
                                        <x:String>key</x:String>
                                    </ComboBox>
                                    <PasswordBox
                                        x:Name="PasswordInput"
                                        Header="Password"
                                        PlaceholderText="Leave blank to keep existing" />
                                    <TextBox
                                        x:Name="KeyPathInput"
                                        Header="Private key path"
                                        PlaceholderText="C:\Users\you\.ssh\id_ed25519" />
                                    <TextBlock
                                        x:Name="SecretStatusText"
                                        Style="{StaticResource CaptionTextStyle}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InsetPanelStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="NOTES" />
                                    <TextBox
                                        x:Name="NotesInput"
                                        AcceptsReturn="True"
                                        Height="96"
                                        PlaceholderText="Optional notes"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="ServerFormStatusText"
                            Style="{StaticResource CaptionTextStyle}"
                            TextWrapping="WrapWholeWords"
                            VerticalAlignment="Center" />

                        <Button
                            Grid.Column="1"
                            Click="OnDeleteClicked"
                            Content="Delete"
                            Style="{StaticResource DangerButtonStyle}" />

                        <Button
                            Grid.Column="2"
                            Click="OnSaveClicked"
                            Content="Save changes"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
