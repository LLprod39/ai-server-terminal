<Page
    x:Class="MiniProd.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="PREFERENCES" />
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Desktop settings" />
                <TextBlock
                    Style="{StaticResource BodyMutedTextStyle}"
                    Text="Everything is local to this Windows profile." />
            </StackPanel>

            <Button
                Grid.Column="1"
                Click="OnSaveClicked"
                Content="Save settings"
                Style="{StaticResource PrimaryButtonStyle}"
                VerticalAlignment="Top" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource WorkspacePanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Appearance" />

                        <Border Style="{StaticResource InsetPanelStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="VISUALS" />
                                <ComboBox
                                    x:Name="ThemeSelector"
                                    Header="Theme"
                                    HorizontalAlignment="Stretch">
                                    <x:String>Dark</x:String>
                                    <x:String>System</x:String>
                                    <x:String>Light</x:String>
                                </ComboBox>
                                <ToggleSwitch
                                    x:Name="DiagnosticsToggle"
                                    Header="Diagnostics logging"
                                    OffContent="Minimal"
                                    OnContent="Verbose" />
                            </StackPanel>
                        </Border>

                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="Theme changes apply immediately after save." />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource WorkspacePanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="AI assistant" />

                        <Border Style="{StaticResource InsetPanelStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="PROVIDER" />
                                <TextBox
                                    x:Name="AiEndpointInput"
                                    Header="Chat completions endpoint"
                                    PlaceholderText="https://api.openai.com/v1/chat/completions" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="AiModelInput"
                                        Header="Model"
                                        PlaceholderText="gpt-4.1-mini" />
                                    <PasswordBox
                                        x:Name="AiApiKeyInput"
                                        Grid.Column="1"
                                        Header="API key"
                                        PasswordChanged="OnApiKeyChanged" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InsetPanelStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="EXECUTION" />
                                <ToggleSwitch
                                    x:Name="AutoApproveToggle"
                                    Header="Auto-run low risk commands"
                                    OffContent="Disabled"
                                    OnContent="Enabled" />
                                <TextBox
                                    x:Name="AiSystemPromptInput"
                                    AcceptsReturn="True"
                                    Header="System prompt"
                                    Height="140"
                                    PlaceholderText="You are a helpful DevOps assistant..."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource WorkspaceSubtleStyle}">
                            <TextBlock
                                x:Name="SettingsStatusText"
                                Style="{StaticResource CaptionTextStyle}"
                                TextWrapping="WrapWholeWords" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
