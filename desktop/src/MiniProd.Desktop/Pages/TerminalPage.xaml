<Page
    x:Class="MiniProd.Desktop.Pages.TerminalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="14,12,14,14" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Background="{StaticResource ShellTerminalBrush}"
            BorderBrush="{StaticResource ShellStrongBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="0">
            <controls:WebView2 x:Name="TerminalWebView" />
        </Border>

        <Border Grid.Row="1" Style="{StaticResource WorkspaceSubtleStyle}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon
                        FontSize="11"
                        Foreground="{StaticResource ShellSubtleTextBrush}"
                        Glyph="&#xE946;"
                        VerticalAlignment="Center" />
                    <TextBlock
                        x:Name="TerminalStatusText"
                        Style="{StaticResource CaptionTextStyle}"
                        TextWrapping="WrapWholeWords"
                        VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CaptionTextStyle}"
                    Text="Shortcuts: Enter run · Ctrl+Enter AI · Ctrl+J assistant panel"
                    VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Page>
