<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="ShellBackgroundColor">#EEF3FA</Color>
            <Color x:Key="ShellForegroundColor">#0F172A</Color>
            <Color x:Key="ShellCardColor">#FFFFFFFF</Color>
            <Color x:Key="ShellSecondaryColor">#F6F8FC</Color>
            <Color x:Key="ShellPaneColor">#E9EFF8</Color>
            <Color x:Key="ShellInsetColor">#F2F6FC</Color>
            <Color x:Key="ShellMutedColor">#64748B</Color>
            <Color x:Key="ShellBorderColor">#D7DFEB</Color>
            <Color x:Key="ShellStrongBorderColor">#BFCBDE</Color>
            <Color x:Key="ShellPrimaryColor">#3D7BFF</Color>
            <Color x:Key="ShellPrimaryForegroundColor">#FFFFFF</Color>
            <Color x:Key="ShellSuccessColor">#0EA56E</Color>
            <Color x:Key="ShellWarningColor">#D18A1F</Color>
            <Color x:Key="ShellDangerColor">#DC6262</Color>
            <Color x:Key="ShellTerminalColor">#0E1520</Color>
            <Color x:Key="ShellSuccessSubtleColor">#DDF5EB</Color>
            <Color x:Key="ShellWarningSubtleColor">#FDEFD8</Color>
            <Color x:Key="ShellDangerSubtleColor">#FFE5E5</Color>
            <Color x:Key="ShellPrimarySubtleColor">#E2ECFF</Color>
            <Color x:Key="ShellSuccessTextColor">#067647</Color>
            <Color x:Key="ShellWarningTextColor">#9C640E</Color>
            <Color x:Key="ShellDangerTextColor">#B83A3A</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <Color x:Key="ShellBackgroundColor">#0B1018</Color>
            <Color x:Key="ShellForegroundColor">#ECF1F8</Color>
            <Color x:Key="ShellCardColor">#151D2A</Color>
            <Color x:Key="ShellSecondaryColor">#1B2533</Color>
            <Color x:Key="ShellPaneColor">#101722</Color>
            <Color x:Key="ShellInsetColor">#111A28</Color>
            <Color x:Key="ShellMutedColor">#8FA0B5</Color>
            <Color x:Key="ShellBorderColor">#2A3649</Color>
            <Color x:Key="ShellStrongBorderColor">#435672</Color>
            <Color x:Key="ShellPrimaryColor">#5E91FF</Color>
            <Color x:Key="ShellPrimaryForegroundColor">#FFFFFF</Color>
            <Color x:Key="ShellSuccessColor">#31D39B</Color>
            <Color x:Key="ShellWarningColor">#FFBC6B</Color>
            <Color x:Key="ShellDangerColor">#FF8E8E</Color>
            <Color x:Key="ShellTerminalColor">#090F16</Color>
            <Color x:Key="ShellSuccessSubtleColor">#0D2C22</Color>
            <Color x:Key="ShellWarningSubtleColor">#322413</Color>
            <Color x:Key="ShellDangerSubtleColor">#361A1D</Color>
            <Color x:Key="ShellPrimarySubtleColor">#172B49</Color>
            <Color x:Key="ShellSuccessTextColor">#7FF0C4</Color>
            <Color x:Key="ShellWarningTextColor">#FFD49B</Color>
            <Color x:Key="ShellDangerTextColor">#FFB7B7</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <FontFamily x:Key="ShellDisplayFontFamily">Segoe UI Variable Display, Segoe UI, Inter</FontFamily>
    <FontFamily x:Key="ShellTextFontFamily">Segoe UI Variable Text, Segoe UI, Inter</FontFamily>
    <FontFamily x:Key="ShellMonoFontFamily">JetBrains Mono, Cascadia Code, Cascadia Mono, Consolas</FontFamily>

    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="{ThemeResource ShellBackgroundColor}" />
    <SolidColorBrush x:Key="ShellForegroundBrush" Color="{ThemeResource ShellForegroundColor}" />
    <SolidColorBrush x:Key="ShellCardBrush" Color="{ThemeResource ShellCardColor}" />
    <SolidColorBrush x:Key="ShellSecondaryBrush" Color="{ThemeResource ShellSecondaryColor}" />
    <SolidColorBrush x:Key="ShellPaneBrush" Color="{ThemeResource ShellPaneColor}" />
    <SolidColorBrush x:Key="ShellInsetBrush" Color="{ThemeResource ShellInsetColor}" />
    <SolidColorBrush x:Key="ShellSubtleTextBrush" Color="{ThemeResource ShellMutedColor}" />
    <SolidColorBrush x:Key="ShellBorderBrush" Color="{ThemeResource ShellBorderColor}" />
    <SolidColorBrush x:Key="ShellStrongBorderBrush" Color="{ThemeResource ShellStrongBorderColor}" />
    <SolidColorBrush x:Key="ShellPrimaryBrush" Color="{ThemeResource ShellPrimaryColor}" />
    <SolidColorBrush x:Key="ShellPrimaryForegroundBrush" Color="{ThemeResource ShellPrimaryForegroundColor}" />
    <SolidColorBrush x:Key="ShellSuccessBrush" Color="{ThemeResource ShellSuccessColor}" />
    <SolidColorBrush x:Key="ShellWarningBrush" Color="{ThemeResource ShellWarningColor}" />
    <SolidColorBrush x:Key="ShellDangerBrush" Color="{ThemeResource ShellDangerColor}" />
    <SolidColorBrush x:Key="ShellTerminalBrush" Color="{ThemeResource ShellTerminalColor}" />
    <SolidColorBrush x:Key="ShellSuccessSubtleBrush" Color="{ThemeResource ShellSuccessSubtleColor}" />
    <SolidColorBrush x:Key="ShellWarningSubtleBrush" Color="{ThemeResource ShellWarningSubtleColor}" />
    <SolidColorBrush x:Key="ShellDangerSubtleBrush" Color="{ThemeResource ShellDangerSubtleColor}" />
    <SolidColorBrush x:Key="ShellPrimarySubtleBrush" Color="{ThemeResource ShellPrimarySubtleColor}" />
    <SolidColorBrush x:Key="ShellSuccessTextBrush" Color="{ThemeResource ShellSuccessTextColor}" />
    <SolidColorBrush x:Key="ShellWarningTextBrush" Color="{ThemeResource ShellWarningTextColor}" />
    <SolidColorBrush x:Key="ShellDangerTextBrush" Color="{ThemeResource ShellDangerTextColor}" />

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShellTextFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource ShellForegroundBrush}" />
    </Style>

    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShellDisplayFontFamily}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShellDisplayFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShellDisplayFontFamily}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="160" />
        <Setter Property="Foreground" Value="{StaticResource ShellSubtleTextBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="BodyMutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource ShellSubtleTextBrush}" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource ShellSubtleTextBrush}" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShellMonoFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource ShellSubtleTextBrush}" />
    </Style>

    <Style x:Key="SuccessTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ShellSuccessTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="DangerTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ShellDangerTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="WarningTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ShellWarningTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="{StaticResource ShellSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="{StaticResource ShellSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource ShellSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
    </Style>

    <Style TargetType="NumberBox">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource ShellSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
    </Style>

    <Style x:Key="WorkspacePanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ShellCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="WorkspaceSubtleStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ShellSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style x:Key="InsetPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ShellInsetBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="HeroCardStyle" TargetType="Border" BasedOn="{StaticResource WorkspacePanelStyle}" />
    <Style x:Key="SectionCardStyle" TargetType="Border" BasedOn="{StaticResource WorkspacePanelStyle}" />
    <Style x:Key="MutedCardStyle" TargetType="Border" BasedOn="{StaticResource WorkspaceSubtleStyle}" />
    <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource WorkspacePanelStyle}" />

    <Style x:Key="AccentCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ShellPrimarySubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="PillBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ShellSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="SuccessBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ShellSuccessSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellSuccessBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="WarningBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ShellWarningSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellWarningBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="DangerBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ShellDangerSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellDangerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ShellPrimaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ShellPrimaryForegroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontFamily" Value="{StaticResource ShellTextFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ShellSecondaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ShellForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontFamily" Value="{StaticResource ShellTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ShellDangerBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ShellDangerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="FontFamily" Value="{StaticResource ShellTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ShellSubtleTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="FontFamily" Value="{StaticResource ShellTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SuccessButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ShellSuccessBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontFamily" Value="{StaticResource ShellTextFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>
</ResourceDictionary>
