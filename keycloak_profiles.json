{
  "default_profile": "test",
  "profiles": {
    "prod": {
      "name": "Production Keycloak",
      "base_url_env": "KEYCLOAK_PROD_URL",
      "realm_env": "KEYCLOAK_PROD_REALM",
      "token_realm_env": "KEYCLOAK_PROD_TOKEN_REALM",
      "client_id_env": "KEYCLOAK_PROD_CLIENT_ID",
      "admin_user_env": "KEYCLOAK_PROD_ADMIN_USER",
      "admin_password_env": "KEYCLOAK_PROD_ADMIN_PASSWORD",
      "verify_ssl_env": "KEYCLOAK_PROD_VERIFY_SSL"
    },
    "test": {
      "name": "Test Keycloak",
      "base_url_env": "KEYCLOAK_TEST_URL",
      "realm_env": "KEYCLOAK_TEST_REALM",
      "token_realm_env": "KEYCLOAK_TEST_TOKEN_REALM",
      "client_id_env": "KEYCLOAK_TEST_CLIENT_ID",
      "admin_user_env": "KEYCLOAK_TEST_ADMIN_USER",
      "admin_password_env": "KEYCLOAK_TEST_ADMIN_PASSWORD",
      "verify_ssl_env": "KEYCLOAK_TEST_VERIFY_SSL"
    }
  }
}
